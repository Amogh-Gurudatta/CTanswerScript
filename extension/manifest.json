{
  "manifest_version": 3,
  "name": "CT Answer Script Exporter",
  "version": "1.0.0",
  "description": "Export CodeTantra exam results as a consolidated PDF for LLM analysis",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*.codetantra.com/*",
    "https://ct-public-bucket.s3.ap-south-1.amazonaws.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ct-exporter@kedarmallya",
      "strict_min_version": "128.0"
    }
  }
}
